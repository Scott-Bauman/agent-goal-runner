{
  "compilerOptions": {
    "target": "ES2022",
    "paths": {
      "@/*": ["./src/*"]
    },
    "useDefineForClassFields": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  }
}
